# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# SearXNG internal signing key — required even on localhost, not a user-facing password.
# Generate with: openssl rand -hex 32
MY_SEARX_SECRET=

# Search provider API keys (only needed for the provider you configure in config/web_search.yaml)
BRAVE_API_KEY=
TAVILY_API_KEY=
